{
  "name": "@context-med/social-agent",
  "version": "0.6.0",
  "description": "Standalone social operations CLI and UI package for Context-Med.",
  "private": true,
  "type": "commonjs",
  "main": "./src/api.js",
  "exports": {
    ".": "./src/api.js"
  },
  "bin": {
    "social-agent": "./bin/cli.js"
  },
  "scripts": {
    "test": "jest --verbose",
    "test:cli": "jest tests/cli/ --verbose",
    "demo:build": "node ./demo/comprehensive-demo.js",
    "ui:dev": "vite --config demo/standalone-ui/vite.config.mjs --host 127.0.0.1 --port 5173",
    "ui:build": "vite build --config demo/standalone-ui/vite.config.mjs",
    "ui:preview": "vite preview --config demo/standalone-ui/vite.config.mjs --host 127.0.0.1 --port 4173",
    "start": "node ./bin/cli.js serve",
    "cli": "node ./bin/cli.js"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "jest": "^29.7.0",
    "vite": "^6.4.2"
  },
  "engines": {
    "node": ">=18"
  }
}
