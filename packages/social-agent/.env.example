# Copy to .env for local standalone demo runs.
# Never commit real API keys.

# Default: keep demos/tests deterministic without any live API.
LLM_PROVIDER=mock
LLM_MODEL=mock-deterministic-social-agent

# Gemini option:
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=

# Groq option:
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.1-70b-versatile
GROQ_API_KEY=

# OpenRouter option:
# LLM_PROVIDER=openrouter
# LLM_MODEL=meta-llama/llama-3.1-70b-instruct
OPENROUTER_API_KEY=
